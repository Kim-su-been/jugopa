# 백엔드 환경변수 템플릿 — 실제 .env(또는 운영 시크릿)는 커밋 금지
# 로컬 개발에서는 DATABASE_URL/USE_S3 를 비워두면 SQLite + 파일시스템으로 동작한다.

# ── Django ──────────────────────────────────────────────
SECRET_KEY=change-me
DEBUG=True

# 운영 호스트/오리진 (콤마 구분)
# ALLOWED_HOSTS=jugopa-backend.onrender.com
# CSRF_TRUSTED_ORIGINS=https://jugopa-backend.onrender.com,https://jugopa.vercel.app
# CORS_ALLOWED_ORIGINS=https://jugopa.vercel.app

# ── Database (운영: Supabase Postgres) ──────────────────
# 미설정 시 로컬 SQLite 폴백. 운영은 Supabase Session Pooler URI 권장.
# DATABASE_URL=postgres://postgres.<project>:<password>@<host>:6543/postgres

# ── 외부 API ────────────────────────────────────────────
FINANCIAL_API_KEY=

GMS_API_KEY=
GMS_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
GMS_MODEL=gpt-5-nano

GMS_API_KEY2=
GMS_BASE_URL2=https://gms.ssafy.io/gmsapi/api.openai.com/v1
GMS_MODEL2=gpt-5-nano

# ── Supabase Storage (운영 미디어 저장, S3 호환) ─────────
# USE_S3=True
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=media
# AWS_S3_ENDPOINT_URL=https://<project>.supabase.co/storage/v1/s3
# AWS_S3_REGION_NAME=ap-northeast-2

AWS_S3_CUSTOM_DOMAIN=<project-ref>.supabase.co/storage/v1/object/public/media